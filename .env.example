# ============================================================
# Modèle de configuration pour SiteCPE
#   - Copier ce fichier en `.env`
#   - Remplir les valeurs réelles
#   - NE JAMAIS committer le vrai .env
# ============================================================

# ----- Mode -----
# DEBUG=True  -> dev local (SQLite)
# DEBUG=False -> production (PostgreSQL)
DEBUG=True

# Générer avec :
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changez-moi-en-production

# Hôtes autorisés - séparés par des virgules
ALLOWED_HOSTS=localhost,127.0.0.1

# Origines CSRF de confiance (avec scheme) - séparées par des virgules
CSRF_TRUSTED_ORIGINS=http://localhost,http://127.0.0.1

# ----- Base de données -----
# Laisser vide en dev pour utiliser SQLite (db.sqlite3)
# En prod : postgres://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=

# ----- Fuseau horaire -----
TIME_ZONE=Africa/Douala

# ----- Sécurité HTTPS (uniquement en prod, DEBUG=False) -----
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
